{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://wdtdpyibiroufejijsmw.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "yampa-mcp",
      "version": "0.1.0",
      "title": "Yampa CRM"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the identity of the signed-in Yampa user backing this MCP connection.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_opportunities",
        "title": "List opportunities",
        "description": "List sales opportunities visible to the signed-in user. Optional filters by stage and text search on name/company.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "stage": {
              "type": "string",
              "description": "Filter by stage slug (e.g. novo_lead, negociacao, fechado_won)."
            },
            "search": {
              "type": "string",
              "description": "Case-insensitive substring match against name and company."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Max rows to return (default 50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_opportunity",
        "title": "Get opportunity",
        "description": "Fetch a single opportunity by id, including all fields the signed-in user is allowed to see.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "description": "Opportunity id (UUID)."
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_commissions",
        "title": "List commissions",
        "description": "List commissions visible to the signed-in user. Optional filters by status and payment month (YYYY-MM).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "Filter by status (e.g. provisioned, paid, canceled)."
            },
            "payment_month": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}$",
              "description": "Filter by payment month in YYYY-MM format."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "description": "Max rows to return (default 100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_chatwoot_conversations",
        "title": "List Chatwoot conversations",
        "description": "List recent Chatwoot conversations synced into Yampa. Optional filters by status and contact email or phone.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "Conversation status (e.g. open, resolved, pending)."
            },
            "contact": {
              "type": "string",
              "description": "Substring match against contact email or phone."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Max rows to return (default 50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
